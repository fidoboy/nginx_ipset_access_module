user  nginx;
worker_processes  auto;

# Dynamic module load (if compiled with --add-dynamic-module):
# load_module modules/ngx_http_ipset_access.so;

events {
    worker_connections  1024;
}

http {
    include       mime.types;
    default_type  application/octet-stream;

    # A blacklist configured at http{} level applies to every server,
    # unless overridden below. Add both an IPv4 and an IPv6 ipset:
    #   sudo ipset create blacklist4 hash:ip family inet
    #   sudo ipset create blacklist6 hash:ip family inet6
    blacklist blacklist4 blacklist6;

    server {
        listen       80;
        listen       [::]:80;
        server_name  example.com;

        location / {
            root   /usr/share/nginx/html;
        }
    }
}
